# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.
# Monorepo root — patterns are intentionally un-anchored so they match every
# workspace (Care/web, Workforce/web, shared, mobile/*).

# dependencies
node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
coverage/

# next.js
.next/
out/

# production builds
build/
dist/

# expo / react-native
.expo/
.expo-shared/
*.jks
*.p8
*.p12
*.mobileprovision
*.orig.*

# native ios/android build output
ios/build/
ios/Pods/
android/.gradle/
android/app/build/

# misc
.DS_Store
*.pem

# secrets
secrets/

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# session logs / ephemeral dev artifacts
.session-log.json
.dev-server*.log
.playwright-mcp/
test-results/
playwright-report/
**/scripts/_e2e_shots/
.tmp-vercel-*

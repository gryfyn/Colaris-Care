# ============================================================================
# COLARIS PLATFORM — root environment template
# ----------------------------------------------------------------------------
# Copy to .env (gitignored) and fill in. Each web app also has its own
# Care/web/.env.local and Workforce/web/.env.local; values here document the
# shared platform tech stack. Real keys are NOT committed.
# ============================================================================

# ── App ─────────────────────────────────────────────────────────────────────
NODE_ENV=development

# ── Database: Neon (serverless Postgres) ────────────────────────────────────
# Neon console → connection string. Use the POOLED connection for serverless.
# Example: postgresql://USER:PASSWORD@ep-xxxx-pooler.REGION.aws.neon.tech/colaris?sslmode=require
DATABASE_URL=postgresql://USER:PASSWORD@HOST.neon.tech/colaris?sslmode=require
DATABASE_SSL=true
DATABASE_SSL_REJECT_UNAUTHORIZED=true

# ── Redis: Upstash (REST) ───────────────────────────────────────────────────
# Upstash console → REST API. Used for rate limiting, sessions, ephemeral cache.
UPSTASH_REDIS_REST_URL=https://YOUR-DB.upstash.io
UPSTASH_REDIS_REST_TOKEN=

# ── Object storage: Cloudflare R2 (S3-compatible) ───────────────────────────
# R2 → Manage R2 API Tokens. Endpoint: https://<ACCOUNT_ID>.r2.cloudflarestorage.com
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=colaris
R2_ENDPOINT=https://ACCOUNT_ID.r2.cloudflarestorage.com
R2_PUBLIC_BASE_URL=

# ── Email: Resend ───────────────────────────────────────────────────────────
RESEND_API_KEY=
EMAIL_FROM="Colaris <noreply@yourdomain.com>"

# ── Monitoring: Sentry ──────────────────────────────────────────────────────
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.1

# ── Auth / JWT (RS256) ──────────────────────────────────────────────────────
JWT_PRIVATE_KEY_PATH=./secrets/jwt.private.pem
JWT_PUBLIC_KEY_PATH=./secrets/jwt.public.pem
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=8h
COOKIE_SECRET=change-me-in-production

# ── Security ────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
AUTH_RATE_LIMIT_MAX=5

# ------------------------------------------------------------
# Next.js app
# ------------------------------------------------------------
NODE_ENV=development
NEXT_PUBLIC_API_URL=http://localhost:3000/api

# ------------------------------------------------------------
# PostgreSQL
# ------------------------------------------------------------
DATABASE_URL=postgresql://postgres:password@localhost:5432/colaris_db
MIGRATION_DATABASE_URL=
DATABASE_SSL=false
DATABASE_SSL_REJECT_UNAUTHORIZED=true

# ------------------------------------------------------------
# Optional shared store for rate limiting / token blacklist
# ------------------------------------------------------------
REDIS_URL=
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ------------------------------------------------------------
# Cloudinary resident face sheet photo uploads
# ------------------------------------------------------------
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ------------------------------------------------------------
# JWT Keys (RS256)
# ------------------------------------------------------------
JWT_PRIVATE_KEY_BASE64=
JWT_PUBLIC_KEY_BASE64=
JWT_PRIVATE_KEY_PATH=./secrets/jwt.private.pem
JWT_PUBLIC_KEY_PATH=./secrets/jwt.public.pem
JWT_SECRET=
JWT_ACCESS_EXPIRES_IN=2h
JWT_REFRESH_EXPIRES_IN=8h

# ------------------------------------------------------------
# Security
# ------------------------------------------------------------
ALLOWED_ORIGINS=http://localhost:3000
COOKIE_SECRET=change-me-in-production
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
AUTH_RATE_LIMIT_MAX=5

# ------------------------------------------------------------
# Logging
# ------------------------------------------------------------
LOG_LEVEL=info

# ------------------------------------------------------------
# PHI Encryption Configuration
# ------------------------------------------------------------
ENCRYPTION_KEY_STRATEGY=env-var
KMS_REGION=us-east-1
KMS_RESIDENT_ENCRYPTION_KEY_ID=
VAULT_ADDR=
VAULT_TOKEN=
ENCRYPTION_KEY_FILE_PATH=
TENANT_ENCRYPTION_KEY=
DEV_TENANT_ENCRYPTION_KEY=dev-only-32-char-key-change-me!!
ENCRYPTION_KEY_CACHE_TTL_MS=3600000
VALIDATE_ENCRYPTION_KEYS=false

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["app", "audit_log", "care"]
}

model schema_migrations {
  filename   String   @id
  applied_at DateTime @default(now()) @db.Timestamptz(6)

  @@schema("app")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model audit_events {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organization_id String?  @db.Uuid
  facility_id     String?  @db.Uuid
  occurred_at     DateTime @default(now()) @db.Timestamptz(6)
  actor_user_id   String?  @db.Uuid
  actor_staff_id  String?  @db.Uuid
  session_id      String?  @db.Uuid
  action          String
  target_type     String?
  target_id       String?  @db.Uuid
  outcome         String   @default("success")
  reason          String?
  correlation_id  String?
  request_id      String?
  source_ip       String?
  metadata        Json     @default("{}")
  previous_hash   String?
  event_hash      String?

  @@index([organization_id, target_type, target_id, occurred_at(sort: Desc)], map: "audit_events_target_idx")
  @@schema("audit_log")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model admission_cases {
  id                   String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organization_id      String     @db.Uuid
  facility_id          String     @db.Uuid
  case_number          String
  candidate_first_name String
  candidate_last_name  String
  status               String     @default("draft")
  current_step         String?
  answers              Json       @default("{}")
  version              Int        @default(1)
  created_at           DateTime   @default(now()) @db.Timestamptz(6)
  created_by           String?    @db.Uuid
  updated_at           DateTime   @default(now()) @db.Timestamptz(6)
  updated_by           String?    @db.Uuid
  facilities           facilities @relation(fields: [organization_id, facility_id], references: [organization_id, id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([organization_id, facility_id, case_number])
  @@schema("care")
}

